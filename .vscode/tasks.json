{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build with make",
			"type": "shell",
			"command": "mingw32-make",
			"options": {
				"cwd": "${workspaceFolder}/brocode1"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": "$gcc"
		},
		{
			"type": "cppbuild",
			"label": "C/C++: gcc.exe build active file",
			"command": "C:\\msys64\\mingw64\\bin\\gcc.exe",
			"args": [
				"-fdiagnostics-color=always",
				"-g",
				"${file}",
				"-o",
				"${fileDirname}\\${fileBasenameNoExtension}.exe"
			],
			"options": {
				"cwd": "${fileDirname}"
			},
			"problemMatcher": [
				"$gcc"
			],
			"group": {
				"kind": "build",
				"isDefault": false
			},
			"detail": "Task generated by Debugger."
		},
		{
			"label": "chargeLab make rebuild",
			"type": "shell",
			"command": "mingw32-make",
			"args": [
				"-C",
				"chargeLab",
				"clean",
				"all"
			],
			"isBackground": false
		},
		{
			"label": "chargeLab make rebuild 2",
			"type": "shell",
			"command": "mingw32-make",
			"args": [
				"-C",
				"chargeLab",
				"clean",
				"all"
			],
			"isBackground": false
		},
		{
			"label": "remove stale run exe",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"Remove-Item -Force chargeLab\\run.exe -ErrorAction SilentlyContinue"
			],
			"isBackground": false
		},
		{
			"label": "remove stale run exe direct",
			"type": "shell",
			"command": "Remove-Item",
			"args": [
				"-Force",
				"chargeLab\\run.exe",
				"-ErrorAction",
				"SilentlyContinue"
			],
			"isBackground": false
		},
		{
			"label": "delete stale run exe cmd",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/C",
				"del /Q chargeLab\\run.exe"
			],
			"isBackground": false
		},
		{
			"label": "check run process",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/C",
				"tasklist | findstr /I run.exe"
			],
			"isBackground": false
		},
		{
			"label": "kill and delete run exe",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/C",
				"taskkill /IM run.exe /F >nul 2>nul & del /Q chargeLab\\run.exe"
			],
			"isBackground": false
		},
		{
			"label": "check run process 2",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/C",
				"tasklist | findstr /I run.exe"
			],
			"isBackground": false
		},
		{
			"label": "clear readonly and delete run exe",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/C",
				"attrib -R chargeLab\\run.exe & del /Q chargeLab\\run.exe"
			],
			"isBackground": false
		},
		{
			"label": "verify plain make command",
			"type": "shell",
			"command": "make",
			"args": [
				"-C",
				"chargeLab",
				"clean"
			],
			"isBackground": false
		},
		{
			"label": "verify make inside chargeLab",
			"type": "shell",
			"command": "Set-Location chargeLab; make clean",
			"isBackground": false
		},
		{
			"label": "add make alias to powershell profile",
			"type": "shell",
			"command": "if (!(Test-Path $PROFILE)) { New-Item -ItemType File -Path $PROFILE -Force | Out-Null }; if (-not (Select-String -Path $PROFILE -Pattern '^Set-Alias make mingw32-make$' -Quiet)) { Add-Content -Path $PROFILE -Value 'Set-Alias make mingw32-make' }",
			"isBackground": false
		},
		{
			"label": "verify make alias works",
			"type": "shell",
			"command": "make -C chargeLab clean",
			"isBackground": false
		},
		{
			"label": "install global make shim",
			"type": "shell",
			"command": "$target = Join-Path $env:LOCALAPPDATA 'Microsoft\\WindowsApps\\make.cmd'; Set-Content -Path $target -Encoding Ascii -Value \"@echo off`r`nmingw32-make %*\"",
			"isBackground": false
		},
		{
			"label": "install global make shim 2",
			"type": "shell",
			"command": "$target = Join-Path $env:LOCALAPPDATA 'Microsoft\\WindowsApps\\make.cmd'; Set-Content -Path $target -Encoding Ascii -Value '@echo off`r`nmingw32-make %*'",
			"isBackground": false
		},
		{
			"label": "install local make exe shim",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/C",
				"copy /Y C:\\msys64\\mingw64\\bin\\mingw32-make.exe chargeLab\\make.exe"
			],
			"isBackground": false
		},
		{
			"label": "verify local make exe command",
			"type": "shell",
			"command": "Set-Location chargeLab; make clean",
			"isBackground": false
		},
		{
			"label": "install global make exe shim in windowsapps",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/C",
				"del /Q \"%LOCALAPPDATA%\\Microsoft\\WindowsApps\\make.cmd\" 2>nul & copy /Y C:\\msys64\\mingw64\\bin\\mingw32-make.exe \"%LOCALAPPDATA%\\Microsoft\\WindowsApps\\make.exe\""
			],
			"isBackground": false
		},
		{
			"label": "install global make exe shim powershell",
			"type": "shell",
			"command": "$wa = Join-Path $env:LOCALAPPDATA 'Microsoft\\WindowsApps'; Remove-Item (Join-Path $wa 'make.cmd') -ErrorAction SilentlyContinue; Copy-Item 'C:\\msys64\\mingw64\\bin\\mingw32-make.exe' (Join-Path $wa 'make.exe') -Force",
			"isBackground": false
		},
		{
			"label": "verify global make now",
			"type": "shell",
			"command": "make --version",
			"isBackground": false
		},
		{
			"label": "verify make clean chargeLab",
			"type": "shell",
			"command": "make",
			"args": [
				"-C",
				"chargeLab",
				"clean"
			],
			"isBackground": false
		},
		{
			"label": "verify make build chargeLab",
			"type": "shell",
			"command": "make",
			"args": [
				"-C",
				"chargeLab"
			],
			"isBackground": false
		},
		{
			"label": "final verify make commands",
			"type": "shell",
			"command": "make",
			"args": [
				"-C",
				"chargeLab"
			],
			"isBackground": false
		},
		{
			"label": "remove blocked powershell profile alias file",
			"type": "shell",
			"command": "Remove-Item",
			"args": [
				"-Force",
				"$HOME\\OneDrive\\Documents\\WindowsPowerShell\\Microsoft.PowerShell_profile.ps1",
				"-ErrorAction",
				"SilentlyContinue"
			],
			"isBackground": false
		},
		{
			"label": "verify make command clean output",
			"type": "shell",
			"command": "make",
			"args": [
				"-C",
				"chargeLab",
				"clean"
			],
			"isBackground": false
		},
		{
			"label": "final check make clean",
			"type": "shell",
			"command": "make",
			"args": [
				"-C",
				"chargeLab",
				"clean"
			],
			"isBackground": false
		},
		{
			"label": "final check make",
			"type": "shell",
			"command": "make",
			"args": [
				"-C",
				"chargeLab"
			],
			"isBackground": false
		},
		{
			"label": "stop app and verify make flow",
			"type": "shell",
			"command": "cmd",
			"args": [
				"/C",
				"taskkill /IM app.exe /F >nul 2>nul & make -C chargeLab clean & make -C chargeLab"
			],
			"isBackground": false
		},
		{
			"label": "verify make in chargeLab after shell fix",
			"type": "shell",
			"command": "make",
			"args": [
				"-C",
				"chargeLab",
				"clean",
				"all"
			],
			"isBackground": false
		},
		{
			"label": "verify make cross-shell after shell pin",
			"type": "shell",
			"command": "make",
			"args": [
				"-C",
				"chargeLab",
				"clean",
				"all"
			],
			"isBackground": false
		},
		{
			"label": "verify make from windows side still works",
			"type": "shell",
			"command": "make",
			"args": [
				"-C",
				"chargeLab",
				"clean",
				"all"
			],
			"isBackground": false
		}
	]
}